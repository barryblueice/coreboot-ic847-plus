if BOARD_RSODIUM_WIDGET

config BOARD_SPECIFIC_OPTIONS
	def_bool y
	select NORTHBRIDGE_INTEL_SANDYBRIDGE
	select SOUTHBRIDGE_INTEL_C216
	select CPU_INTEL_MODEL_206AX
	select USE_NATIVE_RAMINIT
	select HAVE_ACPI_TABLES
	select HAVE_ACPI_RESUME
	select BOARD_ROMSIZE_KB_8192
	select MAINBOARD_HAS_LIBGFXINIT
	select INTEL_GMA_HAVE_VBT
	select GFX_GMA_IGNORE_PRESENCE_STRAPS
	select MAINBOARD_USES_IFD_GBE_REGION
	select HAVE_OPTION_TABLE

config MAINBOARD_DIR
	default "RSODIUM/widget"

config MAINBOARD_PART_NUMBER
	default "IC847-PLUS"

config GFX_GMA_PANEL_1_PORT
	default "Disabled"

# Use a custom FMAP with an enlarged CONSOLE region (2MB) so the full
# EDK2 payload cbmem log can be captured to SPI flash for debugging.
config FMDFILE
	default "src/mainboard/$(CONFIG_MAINBOARD_DIR)/board.fmd"

config CONSOLE_SPI_FLASH_BUFFER_SIZE
	default 0x200000

config CONSOLE_CBMEM_BUFFER_SIZE
	default 0x200000

endif
